# Runtime outputs
artifacts/logs/
plots/
docs/reports/*.json

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.pytest_cache/

# Feast local registry DB
/feature_store/
*.db

# IDE
.vscode/
.idea/
